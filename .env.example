# ──────────────────────────────────────────────────────────────────────────────
# AI Dev Orchestrator — environment variables
# Copy to `.env` and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Fine-grained PAT against the target repo.
# Required scopes: Contents: Read and write, Pull requests: Read and write, Metadata: Read.
# For SAML-protected orgs the PAT must also be SSO-authorized.
GITHUB_PAT=

# HTTPS URL of the target repository the orchestrator will manage.
# Auth flows entirely through GITHUB_PAT; no SSH keys are needed.
REPO_URL=

# Mount path inside the container where the repo is cloned.
REPO_PATH=/repo

# Shared secret configured on the GitHub webhook (used to verify X-Hub-Signature-256).
GITHUB_WEBHOOK_SECRET=

# Default branch name used for PR base + `git diff main...HEAD`.
GIT_DEFAULT_BRANCH=main

# ─── Linear ───────────────────────────────────────────────────────────────────
# API key (Linear Settings → API → Personal API Keys).
LINEAR_API_KEY=

# Shared secret for Linear webhook signature verification.
LINEAR_WEBHOOK_SECRET=

# ─── Slack ────────────────────────────────────────────────────────────────────
# Incoming webhook URL for pipeline notifications.
SLACK_WEBHOOK_URL=

# ─── Claude Code CLI auth ─────────────────────────────────────────────────────
# Dev/staging: 1-year OAuth token generated via `claude setup-token` on your
# local machine. Draws from Pro/Max subscription quota.
CLAUDE_CODE_OAUTH_TOKEN=

# Production: pay-per-token API key. If set, takes precedence over the OAuth
# token. See TDD §4.1 Claude Auth Strategy.
ANTHROPIC_API_KEY=

# ─── Orchestrator tuning ──────────────────────────────────────────────────────
# Max concurrent Claude Code CLI subprocesses.
MAX_PARALLEL_AGENTS=3

# Max review cycles before a PR is opened with NEEDS ATTENTION.
MAX_REVIEW_CYCLES=2

# Reconciliation poll interval (ms). Default = 5 minutes.
RECONCILE_INTERVAL_MS=300000

# Auto-merge: set to true to merge PRs immediately after a clean reviewer pass.
# Flagged PRs (review cycles exhausted) are never auto-merged.
# If the merge fails (e.g. branch protection rules, required checks), the
# pipeline falls back to opening the PR for manual merge.
AUTO_MERGE=false
AUTO_MERGE_STRATEGY=merge   # squash | merge | rebase

# Override the model used for the reviewer agent.
# Defaults to claude-haiku-4-5 (fast and sufficient for rubric evaluation).
# REVIEWER_MODEL=claude-haiku-4-5

# HTTP server port (ngrok routes to this).
PORT=3000

# Log output format. "pretty" → human-readable, colored, columnar (great for
# `docker compose up`). "json" → one NDJSON line per event (use for production
# log aggregators). Defaults to "pretty" unless NODE_ENV=production.
LOG_FORMAT=pretty

# ─── ngrok tunnel sidecar ─────────────────────────────────────────────────────
# Auth token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Fixed domain from https://dashboard.ngrok.com/domains (e.g. labra.ngrok-free.dev)
NGROK_DOMAIN=
