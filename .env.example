# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Linear
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=
LINEAR_READY_STATE_ID=

# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# DB
DATABASE_URL=

# Orchestrator
MAX_OPEN_PRS=3
PORT=3000

# Optional: default branch for PR base and branch creation (default: main)
GITHUB_DEFAULT_BRANCH=main

# Comma-separated repo paths (files or directories) for implementer context.
# Directory entries are fetched recursively (max 200 files total); configure per target repo.
# Fulreach-style example:
# GITHUB_CONTEXT_PATHS=README.md,apps/api/src,apps/workers/src,packages/shared/src,supabase/migrations
GITHUB_CONTEXT_PATHS=README.md
